{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Weekly Language Lesson Plan",
  "description": "The complete structure for a 7-day language lesson plan.",
  "type": "object",
  "properties": {
    "week": { "type": "number" },
    "path": { "type": "string", "enum": ["survival", "alphabet", "numbers"] },
    "targetLanguage": { "type": "string" },
    "nativeLanguage": { "type": "string" },
    "days": {
      "type": "array",
      "description": "An array containing exactly 7 daily lesson objects.",
      "minItems": 7,
      "maxItems": 7,
      "items": { "$ref": "#/definitions/DailyLesson" }
    }
  },
  "required": ["week", "path", "targetLanguage", "nativeLanguage", "days"],
  "definitions": {
    "DailyLesson": {
      "type": "object",
      "properties": {
        "week": { "type": "number" },
        "day": { "type": "number", "minimum": 1, "maximum": 7 },
        "title": { "type": "string" },
        "title_native": { "type": "string" },
        "theme": { "type": "string" },
        "path": { "type": "string", "enum": ["survival", "alphabet", "numbers"] },
        "targetLanguage": { "type": "string" },
        "nativeLanguage": { "type": "string" },
        "words": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/LessonItem" }
        },
        "dialogues": {
          "type": "array",
          "items": { "$ref": "#/definitions/Dialogue" }
        },
        "exercises": { "$ref": "#/definitions/Exercises" },
        "cultural_note": { "type": "string" },
        "pronunciation_tip": { "type": "string" },
        "progress": { "$ref": "#/definitions/Progress" }
      },
      "required": ["week", "day", "title", "title_native", "theme", "path", "targetLanguage", "nativeLanguage", "words", "exercises", "cultural_note", "pronunciation_tip", "progress"]
    },
    "LessonItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "target": { "type": "string" },
        "phonetic": { "type": "string" },
        "native_meaning": { "type": "string" },
        "english": { "type": "string" },
        "example_sentence_target": { "type": "string" },
        "example_sentence_native": { "type": "string" }
      },
      "required": ["id", "target", "phonetic", "native_meaning", "english", "example_sentence_target", "example_sentence_native"]
    },
    "Dialogue": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "context": { "type": "string" },
        "lines": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/DialogueLine" }
        }
      },
      "required": ["id", "context", "lines"]
    },
    "DialogueLine": {
      "type": "object",
      "properties": {
        "speaker": { "type": "string", "enum": ["A", "B"] },
        "target": { "type": "string" },
        "native": { "type": "string" },
        "phonetic": { "type": "string" }
      },
      "required": ["speaker", "target", "native", "phonetic"]
    },
    "Exercises": {
      "type": "object",
      "properties": {
        "fillBlanks": { "type": "array", "items": { "$ref": "#/definitions/FillBlankExercise" } },
        "multipleChoice": { "type": "array", "items": { "$ref": "#/definitions/MultipleChoiceExercise" } },
        "matching": { "type": "array", "items": { "$ref": "#/definitions/MatchingPair" } }
      }
    },
    "FillBlankExercise": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sentence": { "type": "string" },
        "answer": { "type": "string" },
        "hint": { "type": "string" }
      },
      "required": ["id", "sentence", "answer", "hint"]
    },
    "MultipleChoiceExercise": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" }, "minItems": 4, "maxItems": 4 },
        "correct": { "type": "number" },
        "explanation": { "type": "string" }
      },
      "required": ["id", "question", "options", "correct", "explanation"]
    },
    "MatchingPair": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "target": { "type": "string" },
        "native": { "type": "string" }
      },
      "required": ["id", "target", "native"]
    },
    "Progress": {
      "type": "object",
      "properties": {
        "xp": { "type": "number" },
        "streak_bonus": { "type": "number" },
        "badge": { "type": "string" }
      },
      "required": ["xp", "streak_bonus", "badge"]
    }
  }
}
