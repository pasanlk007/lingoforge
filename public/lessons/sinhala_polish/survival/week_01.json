      "dialogues": [
        {
          "id": "d1_1_1", "context": "කඩයකදී ආචාර කිරීම.",
          "lines": [
            {"speaker": "A", "target": "Dzień dobry.", "native": "සුබ දවසක්.", "phonetic": "ජෙන් ඩොබ්රි."},
            {"speaker": "B", "target": "Dzień dobry. W czym mogę pomóc?", "native": "සුබ දවසක්. මම ඔබට උදව් කරන්නේ කෙසේද?", "phonetic": "ජෙන් ඩොබ්රි. ෆ් චිම් මොගෙ පෝමූස්?"}
          ]
        },
        {
          "id": "d1_1_2", "context": "මිතුරෙකුට ආචාර කිරීම.",
          "lines": [
            {"speaker": "A", "target": "Cześć, Kasia!", "native": "ආයුබෝවන්, කාශියා!", "phonetic": "චෙශ්ච්, කාශියා!"},
            {"speaker": "B", "target": "Cześć, Tomek! Co słychać?", "native": "ආයුබෝවන්, තෝමෙක්! මොකද වෙන්නේ?", "phonetic": "චෙශ්ච්, තෝමෙක්! සෝ ස්විහාච්?"}
          ]
        },
        {
          "id": "d1_1_3", "context": "යමෙකුට ස්තූති කිරීම.",
          "lines": [
            {"speaker": "A", "target": "Masz, to dla ciebie.", "native": "මෙන්න, මේක ඔයාට.", "phonetic": "මාෂ්, තො ද්ලා චෙබ්යේ."},
            {"speaker": "B", "target": "Och, dziękuję bardzo!", "native": "අනේ, බොහොම ස්තූතියි!", "phonetic": "ඕහ්, ජෙන්කුයේ බර්ඩ්සෝ!"}
          ]
        },
        {
          "id": "d1_1_4", "context": "යමෙකුගෙන් සමාව අයැදීම.",
          "lines": [
            {"speaker": "A", "target": "Przepraszam, czy może mi pan pomóc?", "native": "සමාවන්න, ඔබට මට උදව් කළ හැකිද?", "phonetic": "ප්ෂෙප්රාශම්, චි mõże මී පන් පෝමූස්?"},
            {"speaker": "B", "target": "Tak, oczywiście. O co chodzi?", "native": "ඔව්, ඇත්තෙන්ම. මොකක්ද කාරණය?", "phonetic": "තක්, ඔචිවිශ්චියේ. ඕ සෝ හොජි?"}
          ]
        }
      ],
