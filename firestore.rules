
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // USER PROFILES: Only the owner can read/write their own profile.
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // ADMIN USERS: Only the owner of an admin record can read it to check their own status.
    // Writing should be done via the Firebase Console for security.
    match /adminUsers/{userId} {
        allow get: if isOwner(userId);
        allow list, create, update, delete: if false;
    }

    // USER PROGRESS: Allow a user to list their own progress records for a path.
    match /userProgress/{userId}/{path} {
      allow list: if isOwner(userId);
    }

    // USER PROGRESS: User can only read/write their own individual progress documents.
    match /userProgress/{userId}/{path}/{weekId} {
      allow read, write: if isOwner(userId);
    }
  }
}
