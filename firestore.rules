
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // USER PROFILES: Only the owner can read/write their own profile.
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // LESSON CACHE: Publicly readable, but only signed-in users can create/update.
    // This is relaxed for development so the app owner can add content.
    match /lessonCache/{lessonCacheId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isSignedIn();
    }
    
    // ADMIN USERS: Only the owner of an admin record can read it to check their own status.
    // Writing should be done via the Firebase Console for security.
    match /adminUsers/{userId} {
        allow get: if isOwner(userId);
        allow list, create, update, delete: if false;
    }

    // USER PROGRESS (Example for future use)
    match /userProgress/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
