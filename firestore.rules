
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // USER PROFILES: Only the owner can read/write their own profile.
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // LESSON CACHE: Publicly readable, but only admins can create/update.
    match /lessonCache/{lessonCacheId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // ADMIN USERS: Not client-accessible. Managed via Firebase Console.
    match /adminUsers/{userId} {
        allow read, write: if false;
    }

    // USER PROGRESS (Example for future use)
    match /userProgress/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
